# Niouzou — environment template for the self-hosting Docker Compose stack.
# Copy to .env and edit. `docker compose` reads this file automatically.
#
#   cp .env.example .env
#
# (For running the API/PWA outside Docker, see api/.env.example and
#  pwa/.env.example instead — DATABASE_URL/MINIFLUX_URL are built from the
#  POSTGRES_* vars below inside compose, so they aren't set here.)

# ── Secrets (CHANGE THESE) ───────────────────────────────────────────────────
# Postgres password for the app database.
POSTGRES_PASSWORD=niouzou
# Secret used to sign JWTs — use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── Miniflux ─────────────────────────────────────────────────────────────────
# Admin account provisioned automatically on first boot. Niouzou mints its own
# Miniflux API key on demand (see api/niouzou/services/miniflux_bootstrap.py)
# — no manual step required.
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=change-me

# ── AI enrichment (optional) ─────────────────────────────────────────────────
# Leave OPENROUTER_API_KEY empty to run fully without AI (TF-IDF scoring).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── Scoring & feed tuning (optional, defaults shown) ─────────────────────────
SCORE_THRESHOLD=0.0
RANDOM_SURFACE_RATE=0.05
FEED_GRAVITY=1.5
MAX_KEYWORDS_PER_ARTICLE=6

# ── Scheduled jobs (optional, defaults shown) ───────────────────────────────
# Fetch+enrich runs every CRON_FETCH_INTERVAL minutes (E8-S6: APScheduler
# inside the worker — replaces the previous one-shot cron containers).
CRON_FETCH_INTERVAL=15
# UTC hour for the daily keyword-weight recompute (0–23).
CRON_REFRESH_WEIGHTS_HOUR=3

# ── Postgres identity (optional — defaults are fine) ─────────────────────────
POSTGRES_USER=niouzou
POSTGRES_DB=niouzou
# Password used by Miniflux to log into its own database inside the shared
# Postgres. Provisioned by infra/postgres-init/ on the first boot — changing
# this later has no effect unless you also wipe the postgres volume.
MINIFLUX_DB_PASSWORD=miniflux

# ── PWA build (optional) ─────────────────────────────────────────────────────
# Baked into the bundle at build time; must be reachable from the browser.
# Default assumes the API is published on the same host's :8000.
VITE_API_URL=http://localhost:8000/api/v1
