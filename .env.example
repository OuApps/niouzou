# ============================================================================
#  Niouzou — Docker Compose environment. Copy to .env, then edit:
#
#    cp .env.example .env
#
#  Compose reads this file automatically. Only the REQUIRED block has to be
#  changed before the first boot — everything below it already has a working
#  default.
# ============================================================================

# ─── REQUIRED ── change these before the first boot ─────────────────────────
# Signs auth tokens. Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# App database password.
POSTGRES_PASSWORD=change-me
# Miniflux (RSS reader) admin password.
MINIFLUX_ADMIN_PASSWORD=change-me

# ─── AI enrichment ── required for the recommendation features ──────────────
# The LLM generates each article's summary + keywords, which power both the
# keyword score and the embedding-based Smart Match score. Without a key,
# Niouzou is just a plain RSS reader (no scoring, no personalized feed).
OPENROUTER_API_KEY=change-me
# Any OpenRouter model id — defaults to a free Gemma model.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# Model for the article chat (E21). Unset → same as OPENROUTER_MODEL. Pick a
# dialogue/reasoning model here; enrichment can stay on a cheap/fast one.
# CHAT_MODEL=anthropic/claude-sonnet-5
# Let the article chat search the internet (OpenRouter web plugin — works with
# any model, billed per search). Default false.
# CHAT_WEB_SEARCH=true
# The embedding model is local and fixed (Qwen/Qwen3-Embedding-0.6B), so it has
# no setting here. It needs the `embeddings` extra + ~1.5 GB RAM in the worker.

# ─── Optional ── defaults shown; change only if you know why ────────────────
SCORE_THRESHOLD=0.0           # min relevance score to surface an article (0.0–1.0)
RANDOM_SURFACE_RATE=0.05      # share of random low-score articles (anti-bubble)
FEED_GRAVITY=1.5              # how fast older articles drop in ranking
CRON_FETCH_INTERVAL=15        # RSS fetch + enrich cadence, in minutes
CRON_NIGHTLY_REFRESH_HOUR=3   # UTC hour of the nightly weight recompute + rescore

# ─── Compose internals ── fine to leave as-is for local self-hosting ────────
POSTGRES_USER=niouzou
POSTGRES_DB=niouzou
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_DB_PASSWORD=miniflux
# API base URL baked into the PWA bundle at build time — must be reachable from
# the browser and include the /api/v1 suffix. Hosted (custom domain):
# VITE_API_URL=https://api-niouzou.galaxou.com/api/v1
VITE_API_URL=http://localhost:8000/api/v1
# NOTE: the anti-Railway redirect (front bounces *.up.railway.app hits to the
# canonical https://niouzou.galaxou.com) is hardcoded at the top of
# pwa/src/main.tsx — no env var. It fires only on Railway's origin, so it is
# inert for local dev and self-hosting.
# Front-end base URL for user-facing links (shareable /article/{id} links the
# MCP returns; future e-mails). Empty → MCP links degrade to a path-only
# /article/{id}. Hosted: FRONTEND_URL=https://niouzou.galaxou.com. Legacy name
# PUBLIC_APP_URL is still honoured as a fallback.
# FRONTEND_URL=
# Browser origins allowed to call the API (comma-separated). Default * (any
# origin) is fine for local self-hosting; lock it down to your PWA origin when
# exposing the API publicly, e.g. CORS_ORIGINS=https://niouzou.example.com
# CORS_ORIGINS=*
