# Database
DATABASE_URL=postgresql://niouzou:password@localhost:5432/niouzou

# Miniflux
MINIFLUX_URL=http://localhost:8080
MINIFLUX_API_KEY=your_miniflux_api_key_here

# JWT
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
# Optional, defaults shown
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-small

# Scoring (optional, defaults shown)
SCORE_THRESHOLD=0.0
RANDOM_SURFACE_RATE=0.05
FEED_GRAVITY=1.5

# Cron intervals in minutes (optional, defaults shown)
CRON_FETCH_INTERVAL=15
CRON_ENRICH_INTERVAL=30

# --- Local dev only (api/docker-compose.dev.yml) ---
# Bootstraps the Miniflux admin account on first container start.
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=adminpassword