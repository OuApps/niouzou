# Niouzou API — environment template. Copy to .env and fill in.
# See docs/ARCHITECTURE.md for the authoritative variable reference.

# --- Required ---
DATABASE_URL=postgresql://niouzou:niouzou@localhost:5432/niouzou
MINIFLUX_URL=http://localhost:8080
MINIFLUX_API_KEY=your-miniflux-api-key
JWT_SECRET=change-me-to-a-long-random-string

# --- Optional: AI enrichment (OpenRouter) ---
# Leave OPENROUTER_API_KEY unset to run fully without AI (TF-IDF scoring,
# newspaper-derived summaries). Set it to enable LLM summaries + keyword
# extraction and switch scoring to AIKeywordScorer.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TIMEOUT=60

# --- Optional: scoring & feed tuning (sensible defaults shown) ---
# SCORE_THRESHOLD=0.0
# RANDOM_SURFACE_RATE=0.05
# FEED_GRAVITY=1.5

# --- Optional: cron batch sizes & intervals ---
# CRON_FETCH_INTERVAL=15
# CRON_ENRICH_INTERVAL=30
# MINIFLUX_FETCH_BATCH_SIZE=100
# ENRICH_BATCH_SIZE=50
