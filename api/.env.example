# Niouzou API — environment template. Copy to .env and fill in.
# See docs/ARCHITECTURE.md for the authoritative variable reference.

# --- Required ---
DATABASE_URL=postgresql://niouzou:niouzou@localhost:5432/niouzou
MINIFLUX_URL=http://localhost:8080
JWT_SECRET=change-me-to-a-long-random-string

# The Miniflux API key is provisioned automatically on first call (see
# api/niouzou/services/miniflux_bootstrap.py), so it doesn't appear here.

# --- Optional: AI enrichment (OpenRouter) ---
# Leave OPENROUTER_API_KEY unset to run fully without AI (TF-IDF scoring,
# newspaper-derived summaries). Set it to enable LLM summaries + keyword
# extraction and switch scoring to AIKeywordScorer.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_TIMEOUT=60

# --- Optional: public URLs & CORS (hosted deployments) ---
# Base URL of the front-end PWA. Used to build user-facing links (shareable
# /article/{id} deep links the MCP returns; future e-mails). Use it explicitly
# — never request.url. Legacy name PUBLIC_APP_URL is still honoured.
# FRONTEND_URL=https://niouzou.galaxou.com
# Browser origins allowed to call the API (comma-separated; default * = any).
# Lock down to the PWA origin when exposing the API publicly.
# CORS_ORIGINS=https://niouzou.galaxou.com
# NOTE: behind a reverse proxy / custom domain, start uvicorn with
#   --proxy-headers --forwarded-allow-ips="*"
# (already set in api/railway.toml and the Dockerfile CMD) so it trusts
# X-Forwarded-Proto (scheme) and X-Forwarded-For (client IP). The public HOST
# comes from the X-Edge-Host header (Railway rewrites Host / X-Forwarded-Host to
# its internal origin); ForwardedHostMiddleware promotes it automatically — no
# env var needed. No custom Railway domain is used and no *.up.railway.app URL
# is hard-coded anywhere.

# --- Optional: scoring & feed tuning (sensible defaults shown) ---
# SCORE_THRESHOLD=0.0
# RANDOM_SURFACE_RATE=0.05
# FEED_GRAVITY=1.5

# --- Optional: cron batch sizes & intervals ---
# CRON_FETCH_INTERVAL=15
# CRON_ENRICH_INTERVAL=30
# MINIFLUX_FETCH_BATCH_SIZE=100
# ENRICH_BATCH_SIZE=50
