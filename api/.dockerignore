# Keep the build context small and the image clean. The build only needs
# pyproject.toml, uv.lock, alembic.ini and the niouzou/ package.
.venv
.python-version
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local-only config and dev tooling — never bake into the image.
.env
.env.*
docker-compose.dev.yml
Dockerfile
.dockerignore

# Tests and dev scripts aren't shipped (deps installed with --no-dev anyway).
tests/
scripts/

# VCS / editor noise.
.git/
.gitignore
*.md
.DS_Store
